# Локальные логи не храним.
# Стартовые data/posts.json и data/chat.json лежат в репозитории как демо-контент;
# на боевом сервере они наполняются реальными постами и сообщениями.
*.log

# Секреты (ключ ИИ, пароль админки, ключ мануала) — только локально, не в репозитории.
# Шаблон со списком переменных лежит в .env.example.
.env
.env.local
.env.*.local
