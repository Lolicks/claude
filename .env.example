# ==================== helpCisco — переменные окружения ====================
# Скопируй этот файл в .env и впиши свои значения:
#   cp .env.example .env
#
# .env НЕ коммитится в репозиторий (см. .gitignore) — там лежат боевые секреты.
# Значения можно брать в кавычки, если внутри есть пробелы.

# --- Название сайта ---
SITE_NAME=helpCisco

# --- Пароль модерации (admin.php). ОБЯЗАТЕЛЬНО смени! ---
ADMIN_PASSWORD=changeme

# --- Секретный ключ скрытого раздела manual.php ---
MANUAL_KEY=ios-nat-2024

# --- ИИ-поддержка ---
# Провайдер: openrouter | anthropic | openai | none
AI_PROVIDER=openrouter

# API-ключ провайдера. Для OpenRouter — вида sk-or-v1-...
# Если пусто — отвечает встроенный оффлайн-ассистент по NAT (без интернета).
AI_API_KEY=

# Модель:
#   openrouter — z-ai/glm-4.5-air:free, qwen/qwen3-coder:free, openai/gpt-4o-mini (платно)
#   anthropic  — claude-sonnet-4-6
#   openai     — gpt-4o-mini
# Суффикс :free — бесплатно, но с лимитом запросов (при превышении приходит HTTP 429
# и отвечает оффлайн-ассистент). Для стабильной работы возьми платную модель или пополни баланс.
AI_MODEL=z-ai/glm-4.5-air:free

# Системная подсказка ассистента (необязательно — есть значение по умолчанию).
# AI_SYSTEM_PROMPT=Ты — ассистент поддержки helpCisco...
